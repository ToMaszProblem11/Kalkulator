#include <stdio.h>

void wprowadz_tekst(char tab[], int rozmiar)
{
    int znak;
    int i=0;
    while((znak=getchar())!=EOF && znak !='\n' && i<rozmiar -1)
    {
        tab[i]=znak;
        i++;
    }
    tab[i]='\0';
}

void wypisz_tekst(char tab[])
{
    int i=0;
    printf("wprowadzony tekst to: ");
    while(tab[i] != '\0')
    {
        printf("%c", tab[i]);
        i++;
    }
    printf("\n");
}



void odwroc(char txt[]) 
{
    char *ptr = &txt[0];
    while(*ptr != '\0')
    {
        ptr++;
    }
    ptr--;
    
    for(;ptr >= &txt[0]; ptr--)
    {
        printf("%c", *ptr);
    }
    
}

int main() 
{
    int rozmiar=100;
    char txt[100];
    wprowadz_tekst(txt, rozmiar);
    wypisz_tekst(txt);
    printf("rozmiar tablicy: %d\n", (int)(sizeof(txt) / sizeof(char)));
    odwroc(txt);
    return 0;
}
