#include <stdio.h>

void odwroc(char txt[])
{
	char* ptr = &txt[0];
	while (*ptr != '\0')
	{
		ptr++;
	}
	ptr--;

	for (; ptr >= &txt[0]; ptr--)
	{
		printf("%c", *ptr);
	}

}

int main()
{
	char txt[]="abc";
	printf("rozmiar tablicy: %d\n", (int)(sizeof(txt) / sizeof(char)));
	odwroc(txt);
	return 0;
}
