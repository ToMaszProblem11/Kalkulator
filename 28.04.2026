float macierz[2][2] = { {1.0,2.0},{3.0,-1.0} };
float wyznacznik(float *macierz)
{
	(&macierz[0][0]) * (&macierz[1][1]) - (*macierz[0][1]) *(*macierz[1][0]);
	return *macierz;
}

void main()
{
	printf("%f\n", wyznacznik((float *)macierz));
}

