#include <stdio.h>

int wczytaj_liczbe()
{
	int wynik = 0;
	int znak = 1;

	int C = getchar();
	while (C == ' ' || C == '\n' || C == '\t')
	{
		C = getchar();
	}

	if (C == '-')
	{
		znak = -1;
	}

	while (C >= '0' && C <= '9')
	{
		wynik = wynik * 10 + (C - '0');
		C = getchar();
	}
	return wynik * znak;
}

