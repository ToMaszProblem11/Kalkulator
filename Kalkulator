int czy_jest_cyferka_na_wejsciu()
{
	int znaczek = getchar();
	if (znaczek == -1) return 0;
	ungetc(znaczek, stdin);
	return znaczek >= '0' && znaczek <= '9';
}
int tekst_na_liczbe()
{
	int liczba = 0;
	while (czy_jest_cyferka_na_wejsciu())
	{
		liczba = liczba * 10 + (getchar() - '0');
	}
	return liczba;
}
int okresl_dzialanie()
{
	int znaczek = getchar(); 
	if (znaczek == '+') return 1;
	if (znaczek == '-') return 2;
	if (znaczek == '*') return 3;
	if (znaczek == '/') return 4;
	return 0; 
}
int main() 
{
	int liczbaA, dzialanie, liczbaB;
	k_b_z(); 
	liczbaA = tekst_na_liczbe();
	k_b_z(); 
	dzialanie = okresl_dzialanie();
	if (!dzialanie)
	{
		fprintf(stderr, "BŁĄD: Nieznane dzialanie\n");
		return 1;
	}
	k_b_z();
	liczbaB = tekst_na_liczbe();
	printf("Wynik to: ");
	if (dzialanie == 1) {
		printf("%d\n", liczbaA + liczbaB);
	}
	else if (dzialanie == 2) {
		printf("%d\n", liczbaA - liczbaB);
	}
	else if (dzialanie == 3) {
		printf("%d\n", liczbaA * liczbaB);
	}
	else if (dzialanie == 4) {
		if (liczbaB == 0) {
			fprintf(stderr, "BŁĄD: Nie dziel przez zero!\n");
		}
		else {
			printf("%d\n", liczbaA / liczbaB);
		}
	}
	return 0;
}
